### WINDOWS AND WORKSPACES ###
##############################

$builtinWorkspace = name:spotify

{{- if eq .chezmoi.hostname "mandos" }}
workspace = $builtinWorkspace, monitor:eDP-1, persistent:true, default:true

workspace = 1, monitor:HDMI-A-1, default:true
workspace = 2, monitor:HDMI-A-1
workspace = 3, monitor:HDMI-A-1
workspace = 4, monitor:HDMI-A-1
workspace = 5, monitor:HDMI-A-1
workspace = 6, monitor:HDMI-A-1
workspace = 7, monitor:HDMI-A-1
workspace = 8, monitor:HDMI-A-1
workspace = 9, monitor:HDMI-A-1
workspace = 10, monitor:HDMI-A-1
workspace = name:telegram, monitor:HDMI-A-1
workspace = name:gimp, monitor:HDMI-A-1
workspace = name:rocketchat, monitor:HDMI-A-1
workspace = name:whatsup, monitor:HDMI-A-1
workspace = name:obs, monitor:HDMI-A-1
workspace = name:teams, monitor:HDMI-A-1
workspace = name:thunderbird, monitor:HDMI-A-1
workspace = name:rss, monitor:HDMI-A-1
workspace = name:anki, monitor:HDMI-A-1
{{- end }}

windowrule = match:class com.obsproject.Studio, workspace name:obs silent
windowrule = match:class anki, workspace name:anki silent
windowrule = match:class org.mozilla.Thunderbird, workspace name:thunderbird silent
windowrule = match:class io.gitlab.news_flash.NewsFlash, workspace name:rss silent

windowrule = match:class org.gnome.NautilusPreviewer, float 1
windowrule = match:class org.gnome.NautilusPreviewer, move (cursor_x+(min(max(-(monitor_w*0.5)\,0)\,monitor_w-window_w))) (cursor_y+(min(max(-(monitor_h*0.5)\,0)\,monitor_h-window_h)))

windowrule = match:class org.gnome.Calendar, float 1, center 1, size (monitor_w*0.8) (monitor_h*0.8)

# windowrule = match:class org.telegram.desktop, match:title Media viewer, float 1, size (monitor_w*0.8) (monitor_h*0.8)

windowrule = match:class xdg-desktop-portal-gtk, float 1, size (monitor_w*0.8) (monitor_h*0.8)

windowrule = match:class org.gnome.Calculator, float 1

windowrule = match:class .*, match:title Bitwarden, float 1

windowrule = match:class ^chrome.*$, match:title Google Translate, float 1, center 1, size (monitor_w*0.5) (monitor_h*0.5)

windowrule = match:class org.gnome.FileRoller, float 1

windowrule = match:class org.pulseaudio.pavucontrol, float 1, move (cursor_x+(min(max(-(monitor_w*0.5)\,0)\,monitor_w-window_w))) (cursor_y+(min(max(-(monitor_h*0.5)\,0)\,monitor_h-window_h))), size (monitor_w*0.3) (monitor_h*0.4)

windowrule = match:class com.github.finefindus.eyedropper, float 1, size (monitor_w*0.2) (monitor_h*0.4), move (min(max((monitor_w*1)-window_w-20\,0)\,monitor_w-window_w)) (min(max(40\,0)\,monitor_h-window_h))

windowrule = match:class ^(google-chrome)$, match:title ^(Notification|Popup)$, float 1

windowrule = match:class .*, suppress_event maximize

windowrule = match:class ^$, match:title ^$, match:xwayland 1, match:float 1, match:fullscreen 0, match:pin 0, no_focus 1

xwayland {
  force_zero_scaling = true
}
