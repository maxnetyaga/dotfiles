exec-once = [workspace name:rss silent] uwsm app -- newsflash
exec-once = [workspace name:telegram silent] uwsm app -- flatpak run org.telegram.desktop
exec-once = [workspace name:spotify silent] uwsm app -- chromium --profile-directory=Default --app-id=pjibgclleladliembfgfagdaldikeohf
exec-once = [workspace name:anki silent] uwsm app -- anki

{{- if eq .chezmoi.hostname "ulmo" }}
