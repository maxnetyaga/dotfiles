bind = $primaryMod SHIFT, 6, movetoworkspace, 6
bind = $primaryMod SHIFT, 7, movetoworkspace, 7
bind = $primaryMod SHIFT, 8, movetoworkspace, 8
bind = $primaryMod SHIFT, 9, movetoworkspace, 9
bind = $primaryMod SHIFT, 0, movetoworkspace, 10

