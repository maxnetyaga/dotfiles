{{- if eq .chezmoi.hostname "ulmo" }}
$scale = 1.5

monitor = , 3840x2160@60, auto, $scale, bitdepth, 10, cm, srgb
{{- else if eq .chezmoi.hostname "mandos" }}
$scale = 1.25

monitor = HDMI-A-1, 3840x2160@60, 0x0, 1.5, bitdepth, 10, cm, srgb
monitor = eDP-1, 1920x1080@60, 512x1440, $scale
{{- else }}
$scale = 1.0

monitor = , preferred, auto, $scale
{{- end }}

input {
    sensitivity = 1
    touchpad {
        natural_scroll = true
    }

    tablet {
        left_handed = true
    }
}

{{- if eq .chezmoi.hostname "ulmo" }}
exec-once = sudo sunshine
{{- end }}

