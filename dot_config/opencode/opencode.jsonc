{
  "$schema": "https://opencode.ai/config.json",
  "experimental": {
      "disable_paste_summary": true
  },
  "mcp": {
    "figma": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "figma-developer-mcp",
        "--stdio"
      ],
      "environment": {
        "FIGMA_API_KEY": "${FIGMA_API_KEY}"
      },
      "enabled": true
    }
  },
  "lsp": {
      "pyright": {
      "disabled": true
    },
    "basedpyright": {
      "command": ["basedpyright-langserver", "--stdio"],
      "extensions": [".py", ".pyi"]
    },
    "ruff": {
      "command": ["ruff", "server"],
      "extensions": [".py", ".pyi"]
    }
  }
}
