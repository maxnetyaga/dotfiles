{
  "$schema": "https://opencode.ai/config.json",
  "experimental": {
      "disable_paste_summary": true
  },
  "lsp": {
      "pyright": {
      "disabled": true
    },
    "basedpyright": {
      "command": ["basedpyright-langserver", "--stdio"],
      "extensions": [".py", ".pyi"]
    },
    "ruff": {
      "command": ["ruff", "server"],
      "extensions": [".py", ".pyi"]
    }
  }
}
