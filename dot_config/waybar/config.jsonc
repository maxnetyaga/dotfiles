{
  "layer": "top",
  "position": "top",
  "modules-left": ["tray", "hyprland/window"],
  "modules-center": ["hyprland/workspaces"],
  "modules-right": ["custom/timer", "custom/brightness", "pulseaudio", "clock"],

  "tray": {
    "spacing": 10,
    // "icon-size": 8,
  },

  "hyprland/window": {
    "format": "{}",
  },

  "hyprland/workspaces": {
    "active-only": true,
    "persistent-workspaces": {
      "*": 11,
    },
  },

  // ####################################################################### //

  "custom/timer": {
    "exec": "waybar_timer hook",
    "exec-on-event": false,
    "return-type": "json",
    "format": "{0} {icon}",
    "format-icons": {
      "standby": "¾▒½”",
      "running": "¾▒½Ā",
      "paused": "¾▒½×",
    },
    "on-click": "waybar_timer new 180 'notify-send \"Session finished\"'",
    "on-click-middle": "waybar_timer cancel",
    "on-click-right": "waybar_timer togglepause",
    "on-scroll-up": "waybar_timer increase 60 || waybar_timer new 1 'notify-send -u critical \"Timer expired\"'",
    "on-scroll-down": "waybar_timer decrease 60",
  },

  "custom/brightness": {
    "format": "{text}% ŅŹī",
    "signal": 8,
    "exec": "brightness-control get",
    "on-scroll-up": "brightness-control up",
    "on-scroll-down": "brightness-control down",
    "on-click": "brightness-control left_click",
    "on-click-right": "brightness-control right_click",
  },

  "pulseaudio": {
    "format": "{volume}% {icon}",
    "format-bluetooth": "{volume}% {icon}’Ŗö",
    "format-muted": "’æ”",
    "format-icons": {
      "alsa_output.pci-0000_00_1f.3.analog-stereo": "¾▒Ī¼",
      "alsa_output.pci-0000_00_1f.3.analog-stereo-muted": "¾▒Ī¼’æ”",
      "headphone": "’Ćź",
      "hands-free": "’Ćź",
      "headset": "’Ćź",
      "phone": "’éĢ",
      "phone-muted": "Ņ┤Ś",
      "portable": "’éĢ",
      "car": "’å╣",
      "default": ["’Ć¦", "’Ć©"],
    },
    "format-source": "Mic ON",
    "format-source-muted": "Mic OFF",
    "scroll-step": 1,
    "on-click": "killall pavucontrol || pavucontrol",
    "ignored-sinks": ["Easy Effects Sink"],
  },

  "clock": {
    "format": "{:%Y-%m-%d [%B, W-%V, %A] %H:%M}",
    "interval": 5,
    "tooltip": false,
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode": "year",
      "mode-mon-col": 3,
      "weeks-pos": "right",
      "on-scroll": 1,
      "format": {
        "months": "<span color='#ffead3'><b>{}</b></span>",
        "days": "<span color='#ecc6d9'><b>{}</b></span>",
        "weeks": "<span color='#99ffdd'><b>W{}</b></span>",
        "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
        "today": "<span color='#ff6699'><b><u>{}</u></b></span>",
      },
    },
  },
}

