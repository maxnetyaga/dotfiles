#!/bin/bash

MONITOR_NAME="HDMI-A-1" # REPLACE WITH YOUR MONITOR NAME

CURRENT_CM=$(hyprctl monitors | grep "colorManagementPreset:" | awk '{print $2}')
scale=1.5

if [ "$CURRENT_CM" == "hdr" ]; then
    hyprctl keyword monitor "$MONITOR_NAME , 3840x2160@60, auto, $scale, bitdepth, 10, cm, srgb"
    dunstify "HDR Toggled Off (SDR mode)"
else
    hyprctl keyword monitor "$MONITOR_NAME , 3840x2160@60, auto, $scale, bitdepth, 10, cm, hdr"
    dunstify "HDR Toggled On (HDR mode)"
fi
